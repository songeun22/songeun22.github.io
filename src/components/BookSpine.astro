---
import type { ShelfItem } from '../lib/library';

interface Props {
  item: ShelfItem;
  /** Spine height in px. */
  height?: number;
}

const { item, height = 280 } = Astro.props;
const { book, chapters, thickness, planned, href } = item;
const d = book.data;

// Planned books are inert: no colour, no link, no cover to open.
const Tag = planned || !href ? 'div' : 'a';
const chapterLabel = `${chapters.length} ${chapters.length === 1 ? 'chapter' : 'chapters'}`;
---

<li
  class:list={['slot', planned && 'planned']}
  style={`--thickness: ${thickness}px; --h: ${height}px; ${planned ? '' : `--color: ${d.color};`}`}
>
  <Tag class="book" href={planned ? undefined : href} aria-label={planned ? undefined : d.title}>
    <span class="spine">
      <span class="spine-title">{d.title}</span>
    </span>

    <span class="cover" aria-hidden="true">
      <span class="band"></span>
      <span class="cover-body">
        <span class="cover-title">{d.title}</span>
        {d.subtitle && <span class="cover-sub">{d.subtitle}</span>}
        <span class="cover-sum">{d.description}</span>
      </span>
      <span class="cover-meta">{planned ? 'Planned' : chapterLabel}</span>
    </span>
  </Tag>
</li>

<style>
  .slot {
    list-style: none;
    --color: var(--book-grey);
    --cover-w: 210px;
  }

  .book {
    position: relative;
    display: block;
    width: var(--thickness);
    height: var(--h);
    background: var(--color);
    overflow: hidden;
    text-decoration: none;
    /* Flat by design: no shadow, no gradient, no inner bevel. */
    transition: width 0.35s var(--ease);
  }

  /* Opening the book: the spine widens into its front cover. */
  .book:hover,
  .book:focus-visible {
    width: var(--cover-w);
  }

  .slot.planned .book {
    width: var(--thickness);
    cursor: default;
  }

  /* ---- Spine ---- */

  .spine {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    padding-block: var(--space-3);
    transition: opacity 0.2s var(--ease);
  }

  .spine-title {
    writing-mode: vertical-rl;
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    letter-spacing: 0.02em;
    line-height: 1;
    color: #fff;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-height: calc(var(--h) - var(--space-8));
  }

  .slot.planned .spine-title {
    color: var(--book-grey-ink);
    font-weight: var(--weight-medium);
  }

  .book:hover .spine,
  .book:focus-visible .spine {
    opacity: 0;
  }

  /* ---- Front cover ---- */

  .cover {
    position: absolute;
    inset: 0;
    width: var(--cover-w);
    display: flex;
    flex-direction: column;
    padding: var(--space-4);
    opacity: 0;
    transition: opacity 0.25s var(--ease);
    pointer-events: none;
  }

  .book:hover .cover,
  .book:focus-visible .cover {
    opacity: 1;
  }

  .slot.planned .cover {
    display: none;
  }

  /* The one piece of ornament: a flat band across the cover. */
  .band {
    position: absolute;
    left: 0;
    right: 0;
    top: 52px;
    height: 5px;
    background: rgb(255 255 255 / 0.28);
  }

  .cover-body {
    display: flex;
    flex-direction: column;
    margin-top: 72px;
    /* Take the space left over above the meta line, and clip inside it, so
       the summary can never spill over the chapter count. */
    flex: 1;
    min-height: 0;
    overflow: hidden;
  }

  .cover-title {
    font-size: var(--text-lg);
    font-weight: var(--weight-semibold);
    line-height: var(--leading-tight);
    letter-spacing: -0.01em;
    color: #fff;
  }

  .cover-sub {
    margin-top: var(--space-2);
    font-size: var(--text-xs);
    line-height: var(--leading-snug);
    color: rgb(255 255 255 / 0.72);
  }

  .cover-sum {
    margin-top: var(--space-3);
    font-size: var(--text-xs);
    line-height: var(--leading-snug);
    color: rgb(255 255 255 / 0.86);
    overflow: hidden;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    /* Ends on an ellipsis rather than a hard cut mid-word. */
    -webkit-line-clamp: 5;
  }

  .cover-meta {
    padding-top: var(--space-3);
    font-family: var(--font-mono);
    font-size: 10px;
    color: rgb(255 255 255 / 0.7);
  }

  @media (prefers-reduced-motion: reduce) {
    .book {
      transition: none;
    }
  }
</style>
