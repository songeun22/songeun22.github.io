---
/**
 * Static 2x2 Type I / Type II error matrix.
 * Positive = "there's an effect", H0 rejected, H1 accepted.
 */
---

<figure class="matrix">
  <div class="grid">
    <div class="cell corner" aria-hidden="true"></div>
    <div class="cell head col">Fail to reject H₀</div>
    <div class="cell head col">Reject H₀</div>

    <div class="cell head row">H₀ true</div>
    <div class="cell outcome tn">
      <span class="tag">TN</span>
      <span class="label">Correct</span>
    </div>
    <div class="cell outcome err1">
      <span class="tag">FP</span>
      <span class="label">Type I error (α)</span>
    </div>

    <div class="cell head row">H₀ false</div>
    <div class="cell outcome err2">
      <span class="tag">FN</span>
      <span class="label">Type II error (β)</span>
    </div>
    <div class="cell outcome tp">
      <span class="tag">TP</span>
      <span class="label">Power (1−β)</span>
    </div>
  </div>

  <figcaption>Positive means “there's an effect”, H₀ rejected, H₁ accepted.</figcaption>
</figure>

<style>
  .matrix {
    margin: var(--space-8) 0;
    padding: var(--space-4);
    background: var(--bg-subtle);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    font-family: var(--font-sans);
  }

  .grid {
    display: grid;
    grid-template-columns: auto 1fr 1fr;
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
  }

  .cell {
    padding: var(--space-3) var(--space-4);
    background: var(--surface);
    display: flex;
    align-items: center;
  }

  .cell.corner {
    background: var(--bg-subtle);
  }

  .cell.head {
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    color: var(--text-muted);
    background: var(--bg-subtle);
  }

  .cell.head.col {
    justify-content: center;
    text-align: center;
  }

  .cell.outcome {
    flex-direction: column;
    align-items: flex-start;
    gap: 2px;
  }

  .tag {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    color: var(--text);
  }

  .label {
    font-size: var(--text-xs);
    color: var(--text-faint);
  }

  .err1 {
    background: color-mix(in srgb, #c0392b 16%, var(--surface));
  }

  .err1 .tag {
    color: #c0392b;
  }

  .err2 {
    background: color-mix(in srgb, #b8860b 16%, var(--surface));
  }

  .err2 .tag {
    color: #b8860b;
  }

  figcaption {
    margin-top: var(--space-4);
    font-size: var(--text-sm);
    color: var(--text-muted);
  }

  @media (max-width: 480px) {
    .grid {
      grid-template-columns: auto 1fr 1fr;
      font-size: var(--text-sm);
    }
    .cell {
      padding: var(--space-2) var(--space-3);
    }
  }
</style>
