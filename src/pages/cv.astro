---
import Base from '../layouts/Base.astro';
import { site } from '../site.config';
---

<Base title="CV" description={`Curriculum vitae — ${site.name}`} bare>
  <section class="cv">
    <div class="toolbar">
      <p class="label">Curriculum Vitae</p>
      <a class="open" href={site.cv} target="_blank" rel="noopener">
        Open in new tab
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6M15 3h6v6M10 14L21 3"></path>
        </svg>
      </a>
    </div>

    <!-- <object> renders the PDF inline and falls back cleanly when a
         browser (notably mobile Safari) refuses to embed one. -->
    <object class="viewer" data={`${site.cv}#view=FitH`} type="application/pdf">
      <div class="fallback">
        <p>Your browser won't display the PDF inline.</p>
        <a class="btn" href={site.cv} target="_blank" rel="noopener">Open the CV</a>
      </div>
    </object>
  </section>
</Base>

<style>
  .cv {
    max-width: var(--page-max);
    margin-inline: auto;
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    /* Fill the window below the nav; the PDF gets the rest. */
    height: calc(100dvh - var(--nav-h));
  }

  .toolbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    padding-bottom: var(--space-4);
  }

  .label {
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--text-muted);
  }

  .open {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    text-decoration: none;
  }

  .open svg {
    width: 14px;
    height: 14px;
  }

  .viewer {
    flex: 1;
    width: 100%;
    min-height: 0;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg-subtle);
  }

  .fallback {
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-4);
    color: var(--text-muted);
  }

  .btn {
    padding: var(--space-3) var(--space-6);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: #fff;
    background: var(--accent);
    border-radius: 999px;
    text-decoration: none;
  }

  /* Embedded PDFs are unusable on small screens — send them to the file. */
  @media (max-width: 640px) {
    .cv {
      height: auto;
      padding-block: var(--space-12);
    }
    .viewer {
      height: 60vh;
      flex: none;
    }
  }
</style>
