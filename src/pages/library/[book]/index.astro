---
import { getCollection } from 'astro:content';
import { getBookChapters } from '../../../lib/library';

// A book has no page of its own — opening it means opening chapter one.
export async function getStaticPaths() {
  const books = await getCollection('books');

  return Promise.all(
    books.map(async (book) => {
      const chapters = await getBookChapters(book.id);
      return {
        params: { book: book.id },
        props: { first: chapters[0] },
      };
    }),
  );
}

const { first } = Astro.props;

return Astro.redirect(first ? `/library/${first.id}` : '/library');
---
