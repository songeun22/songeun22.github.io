---
import Base from '../../layouts/Base.astro';
import Reveal from '../../components/Reveal.astro';
import BookSpine from '../../components/BookSpine.astro';
import { getShelf } from '../../lib/library';

const shelf = await getShelf();
const written = shelf.filter((s) => !s.planned);
---

<Base
  title="Library"
  description="Walking back through statistics, classical to modern, to find the simple ideas that still have something to say to machine learning."
>
  <header class="head">
    <p class="eyebrow">Library</p>
    <h1>Books I'm writing to think with</h1>
    <p class="lede">
      Coming from a statistics background, I believe some traditional statistical methods can
      contribute to machine learning in strikingly simple ways. This library is my own: a place to
      walk back through statistics — classical to modern — to wake my brain up, and to work out how
      those ideas might apply to a black box like ML if you look at it from a different angle.
    </p>
  </header>

  <div class="bar">
    <p class="count">
      {written.length} written · {shelf.length - written.length} planned
    </p>

    <div class="views" role="group" aria-label="View mode">
      <button type="button" data-view="shelf" aria-pressed="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M4 4v16M9 4v16M14 5l4 15M3 20h18"></path>
        </svg>
        Shelf
      </button>
      <button type="button" data-view="list" aria-pressed="false">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" aria-hidden="true">
          <path d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
        List
      </button>
    </div>
  </div>

  <!-- Shelf view -->
  <section id="view-shelf">
    <Reveal>
      <ul class="shelf">
        {shelf.map((item) => <BookSpine item={item} height={300} />)}
      </ul>
      <div class="plank"></div>
    </Reveal>

    <p class="hint">
      Thickness tracks how much is written. Hover a book to open its cover; grey ones are planned.
    </p>
  </section>

  <!-- List view -->
  <section id="view-list" hidden>
    <ul class="list">
      {
        shelf.map((item, i) => {
          const d = item.book.data;
          const Row = item.href ? 'a' : 'div';
          return (
            <li>
              <Reveal delay={i * 60}>
                <Row class:list={['row', item.planned && 'planned']} href={item.href ?? undefined}>
                  <span
                    class="swatch"
                    style={item.planned ? undefined : `background: ${d.color}`}
                  />
                  <div class="row-main">
                    <h2>
                      {d.title}
                      {d.status !== 'complete' && (
                        <span class="tag">
                          {d.status === 'planned' ? 'planned' : d.status === 'draft' ? 'draft' : 'in progress'}
                        </span>
                      )}
                    </h2>
                    {d.subtitle && <p class="sub">{d.subtitle}</p>}
                    <p class="desc">{d.description}</p>
                  </div>
                  <span class="row-meta">
                    {item.planned
                      ? '—'
                      : `${item.chapters.length} ${item.chapters.length === 1 ? 'chapter' : 'chapters'}`}
                  </span>
                </Row>
              </Reveal>
            </li>
          );
        })
      }
    </ul>
  </section>
</Base>

<style>
  .head {
    max-width: var(--measure);
    padding-block: var(--space-16) var(--space-8);
  }

  .head h1 {
    font-size: var(--text-3xl);
    margin-top: var(--space-2);
  }

  .lede {
    margin-top: var(--space-4);
    font-family: var(--font-serif);
    font-size: var(--text-lg);
    color: var(--text-muted);
  }

  .bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    padding-bottom: var(--space-8);
    border-bottom: 1px solid var(--border);
  }

  .count {
    font-size: var(--text-sm);
    color: var(--text-faint);
  }

  .views {
    display: flex;
    gap: var(--space-1);
    padding: 3px;
    background: var(--bg-subtle);
    border: 1px solid var(--border);
    border-radius: var(--radius);
  }

  .views button {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-3);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--text-muted);
    background: transparent;
    border: 0;
    border-radius: var(--radius-sm);
  }

  .views button svg {
    width: 15px;
    height: 15px;
  }

  .views button[aria-pressed='true'] {
    background: var(--surface);
    color: var(--text);
    box-shadow: 0 1px 2px rgb(0 0 0 / 0.06);
  }

  /* ---- Shelf ---- */

  .shelf {
    display: flex;
    align-items: flex-end;
    gap: 5px;
    list-style: none;
    padding: var(--space-16) 0 0;
    margin: 0;
    min-height: 300px;
    overflow-x: auto;
    overflow-y: hidden;
  }

  /* A plain rule, not a plank with a shadow. */
  .plank {
    height: 3px;
    background: var(--border-strong);
  }

  .hint {
    margin-top: var(--space-4);
    font-size: var(--text-sm);
    color: var(--text-faint);
  }

  /* ---- List ---- */

  .list {
    list-style: none;
    padding: 0;
    margin: var(--space-8) 0 0;
  }

  .row {
    display: grid;
    grid-template-columns: 4px 1fr auto;
    gap: var(--space-6);
    align-items: start;
    padding: var(--space-6) 0;
    border-bottom: 1px solid var(--border);
    text-decoration: none;
    color: inherit;
  }

  .swatch {
    height: 100%;
    min-height: 48px;
    background: var(--book-grey);
  }

  .row.planned {
    cursor: default;
  }

  .row.planned .row-main h2,
  .row.planned .sub,
  .row.planned .desc {
    color: var(--text-faint);
  }

  .row h2 {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-size: var(--text-xl);
  }

  a.row:hover h2 {
    color: var(--accent);
  }

  .tag {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    letter-spacing: 0.04em;
    padding: 2px var(--space-2);
    border-radius: var(--radius-sm);
    background: var(--bg-subtle);
    border: 1px solid var(--border);
    color: var(--text-faint);
  }

  .sub {
    margin-top: var(--space-2);
    font-family: var(--font-serif);
    color: var(--text-muted);
  }

  .desc {
    margin-top: var(--space-2);
    font-size: var(--text-sm);
    line-height: var(--leading-snug);
    color: var(--text-faint);
    max-width: 62ch;
  }

  .row-meta {
    font-size: var(--text-sm);
    color: var(--text-faint);
    white-space: nowrap;
  }

  @media (max-width: 640px) {
    .row {
      grid-template-columns: 4px 1fr;
    }
    .row-meta {
      display: none;
    }
  }
</style>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.views button');
  const views = {
    shelf: document.getElementById('view-shelf'),
    list: document.getElementById('view-list'),
  };

  const apply = (mode: string) => {
    for (const [name, el] of Object.entries(views)) {
      if (el) el.hidden = name !== mode;
    }
    for (const b of buttons) {
      b.setAttribute('aria-pressed', String(b.dataset.view === mode));
    }
    localStorage.setItem('library-view', mode);
  };

  for (const b of buttons) {
    b.addEventListener('click', () => apply(b.dataset.view!));
  }

  const saved = localStorage.getItem('library-view');
  if (saved === 'list' || saved === 'shelf') apply(saved);
</script>
