---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import Reveal from '../components/Reveal.astro';
import { site } from '../site.config';

const entries = await getCollection('timeline');
const timeline = entries.sort((a, b) => a.data.start - b.data.start);

const kindLabel: Record<string, string> = {
  education: 'Education',
  research: 'Research',
  work: 'Work',
};
---

<Base title="About Me" description="A short version of the CV, plus the shape of how I got here.">
  <header class="head">
    <h1>About Me</h1>
  </header>

  <section class="bio">
    <Reveal>
      <div class="prose">
        <p>
          I am a student ML researcher in South Korea, currently pursuing a Bachelor's degree in
          Statistics at Seoul National University.
        </p>
        <p>
          My research interest lies in probabilistic machine learning broadly, and more specifically
          in decision making and uncertainty quantification. I find these fields compelling because
          rigorous uncertainty quantification provides a mathematical language for models to express
          their limits. By transforming raw neural network heuristics into well-calibrated confidence
          measures, we can build a reliable bridge where domain experts, whether in biology (e.g.,
          drug discovery, protein design), physics, or finance, and automated systems can
          collaborate safely in high-stakes environments.
        </p>
        <p>
          I feel lucky to work with <a href="https://juho-lee.github.io/">Prof. Juho Lee</a> and <a href="https://mllab.snu.ac.kr/hyunoh/">Prof. Hyunoh Song</a>.
        </p>
      </div>
    </Reveal>

    <Reveal delay={100}>
      <aside class="card">
        <img class="avatar" src={site.avatar} alt="" width="72" height="72" />
        <dl>
          <div>
            <dt>Email</dt>
            <dd><a href={`mailto:${site.email}`}>{site.email}</a></dd>
          </div>
          <div>
            <dt>CV</dt>
            <dd><a href="/cv">Read the full CV →</a></dd>
          </div>
        </dl>
      </aside>
    </Reveal>
  </section>

  <section class="pub-section">
    <Reveal>
      <h2>Publications</h2>
    </Reveal>

    <ol class="pub-list">
      <li>
        <Reveal>
          <p class="pub-authors"><strong>Songeun Kim</strong>, Seungyoo Lee, Edwin Fong, Hyungi Lee, Juho Lee</p>
          <p class="pub-title">From Drift to Coherence: Stabilizing Beliefs of LLMs</p>
          <p class="pub-meta">ICML 2026 · <a href="https://arxiv.org/abs/2606.17832">arXiv</a></p>
        </Reveal>
      </li>
    </ol>
  </section>

  <section class="tl-section">
    <Reveal>
      <h2>Experience</h2>
    </Reveal>

    <ol class="timeline">
      {
        timeline.map((entry, i) => (
          <li>
            <Reveal delay={i * 90}>
              <div class="entry">
                <div class="marker" data-kind={entry.data.kind}>
                  <span class="dot" />
                </div>
                <div class="body">
                  <p class="period">{entry.data.period}</p>
                  <h3>{entry.data.title}</h3>
                  <p class="org">{entry.data.org}</p>
                  {entry.data.description && <p class="desc">{entry.data.description}</p>}
                  <span class="kind">{kindLabel[entry.data.kind]}</span>
                </div>
              </div>
            </Reveal>
          </li>
        ))
      }
    </ol>
  </section>
</Base>

<style>
  .head {
    padding-block: var(--space-16) var(--space-8);
  }

  .head h1 {
    font-size: var(--text-3xl);
    margin-top: var(--space-2);
  }

  .bio {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 280px;
    gap: var(--space-12);
    align-items: start;
    padding-bottom: var(--space-16);
  }

  .card {
    padding: var(--space-6);
    background: var(--bg-subtle);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
  }

  .card .avatar {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    margin-bottom: var(--space-4);
  }

  dl {
    margin: 0;
    display: grid;
    gap: var(--space-4);
  }

  dt {
    font-size: var(--text-xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-faint);
  }

  dd {
    margin: var(--space-1) 0 0;
    font-size: var(--text-sm);
    word-break: break-word;
  }

  dd a {
    text-decoration: none;
  }

  dd a:hover {
    text-decoration: underline;
  }

  /* ---- Publications ---- */

  .pub-section {
    padding-bottom: var(--space-16);
  }

  .pub-section h2 {
    font-size: var(--text-2xl);
    padding-bottom: var(--space-6);
    border-bottom: 1px solid var(--border);
  }

  .pub-list {
    list-style: none;
    padding: 0;
    margin: var(--space-8) 0 0;
    max-width: 760px;
  }

  .pub-list li + li {
    margin-top: var(--space-6);
  }

  .pub-authors {
    font-size: var(--text-sm);
  }

  .pub-title {
    margin-top: var(--space-1);
    font-family: var(--font-serif);
    font-size: var(--text-lg);
  }

  .pub-meta {
    margin-top: var(--space-1);
    font-size: var(--text-sm);
    color: var(--text-faint);
  }

  /* ---- Timeline ---- */

  .tl-section {
    padding-bottom: var(--space-16);
  }

  .tl-section h2 {
    font-size: var(--text-2xl);
    padding-bottom: var(--space-6);
    border-bottom: 1px solid var(--border);
  }

  .timeline {
    list-style: none;
    padding: 0;
    margin: var(--space-8) 0 0;
    max-width: 760px;
  }

  .entry {
    display: grid;
    grid-template-columns: 24px 1fr;
    gap: var(--space-6);
  }

  /* The rail is drawn by the marker column, so it never orphans. */
  .marker {
    position: relative;
    display: flex;
    justify-content: center;
  }

  .marker::before {
    content: '';
    position: absolute;
    top: 0;
    bottom: -1px;
    width: 1px;
    background: var(--border);
  }

  .timeline li:last-child .marker::before {
    bottom: auto;
    height: 16px;
  }

  .dot {
    position: relative;
    z-index: 1;
    width: 11px;
    height: 11px;
    margin-top: 10px;
    border-radius: 50%;
    background: var(--bg);
    border: 2px solid var(--border-strong);
  }

  .marker[data-kind='research'] .dot {
    border-color: var(--accent);
    background: var(--accent);
  }

  .marker[data-kind='education'] .dot {
    border-color: var(--accent);
  }

  .body {
    padding-bottom: var(--space-12);
  }

  .period {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-faint);
  }

  .body h3 {
    margin-top: var(--space-1);
    font-size: var(--text-lg);
  }

  .org {
    margin-top: var(--space-1);
    font-family: var(--font-serif);
    color: var(--text-muted);
  }

  .desc {
    margin-top: var(--space-3);
    font-size: var(--text-sm);
    line-height: var(--leading-snug);
    color: var(--text-faint);
    max-width: 60ch;
  }

  .kind {
    display: inline-block;
    margin-top: var(--space-3);
    padding: 2px var(--space-2);
    font-size: var(--text-xs);
    color: var(--text-faint);
    background: var(--bg-subtle);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
  }

  @media (max-width: 860px) {
    .bio {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }
  }
</style>
