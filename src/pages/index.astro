---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import Reveal from '../components/Reveal.astro';
import SocialLinks from '../components/SocialLinks.astro';
import BookSpine from '../components/BookSpine.astro';
import { site } from '../site.config';
import { getShelf } from '../lib/library';

const shelf = await getShelf();

// The home page teases; it doesn't dump. Deliberately partial.
const PREVIEW_COUNT = 6;
const gallery = (await getCollection('gallery')).slice(0, PREVIEW_COUNT);

const files = import.meta.glob<{ default: ImageMetadata }>(
  '/src/images/gallery/*.{jpg,jpeg,png,webp,avif}',
  { eager: true },
);

const previews = gallery
  .map((item) => ({ ...item.data, src: files[`/src/images/gallery/${item.data.image}`]?.default }))
  .filter((p) => p.src);
---

<Base>
  <!-- Hero -->
  <section class="hero">
    <Reveal>
      <img class="avatar" src={site.avatar} alt="" width="128" height="128" />
    </Reveal>

    <Reveal delay={80}>
      <h1>{site.name}</h1>
      <p class="tagline">{site.tagline}</p>
    </Reveal>

    <Reveal delay={160}>
      {/* Written out rather than pulled from config so the break lands
          between the sentences, and never inside the name. */}
      <p class="intro">
        Hello, I'm <span class="nowrap">Songeun Kim (김송은)</span> — or you can just call me Olivia.<br
        />
        Welcome to my personal blog!
      </p>
    </Reveal>

    <Reveal delay={240}>
      <div class="cta">
        <a class="btn primary" href="/library">Read the Library</a>
        <a class="btn" href="/about">About me</a>
      </div>

      <SocialLinks />
    </Reveal>

    <div class="scroll-cue" aria-hidden="true">
      <span></span>
    </div>
  </section>

  <!-- Library teaser -->
  <section class="block">
    <Reveal>
      <div class="block-head">
        <h2>From the Library</h2>
        <a class="more" href="/library">See all →</a>
      </div>
    </Reveal>

    <Reveal>
      <ul class="shelf">
        {shelf.map((item) => <BookSpine item={item} height={240} />)}
      </ul>
      <div class="plank"></div>
      <p class="hint">Hover a book to open its cover. Grey ones aren't written yet.</p>
    </Reveal>
  </section>

  <!-- Gallery teaser -->
  <section class="block">
    <Reveal>
      <div class="block-head">
        <h2>Gallery</h2>
        <a class="more" href="/gallery">See all →</a>
      </div>
    </Reveal>

    <div class="mosaic">
      {
        previews.map((p, i) => (
          <Reveal delay={i * 70} class="cell">
            <a href="/gallery" aria-label={p.title}>
              <Image
                src={p.src!}
                alt={p.description ?? p.title}
                widths={[280, 420, 640]}
                sizes="(max-width: 640px) 50vw, 30vw"
                loading="lazy"
              />
              <span class="cap">{p.title}</span>
            </a>
          </Reveal>
        ))
      }
    </div>

    <Reveal>
      <a class="btn see-more" href="/gallery">See more</a>
    </Reveal>
  </section>
</Base>

<style>
  /* ---- Hero ---- */

  .hero {
    position: relative;
    min-height: calc(100dvh - var(--nav-h));
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    gap: var(--space-4);
    padding-block: var(--space-16);
  }

  .avatar {
    width: 166px;
    height: 166px;
    border-radius: 50%;
    background: var(--bg-subtle);
    border: 1px solid var(--border);
  }

  .hero h1 {
    font-size: var(--text-4xl);
    letter-spacing: -0.035em;
  }

  .tagline {
    margin-top: var(--space-2);
    font-size: var(--text-lg);
    color: var(--text-faint);
  }

  .intro {
    /* Wide enough to hold the first sentence on one line, so the authored
       <br> is the only break on a normal screen. */
    max-width: 68ch;
    font-family: var(--font-serif);
    font-size: var(--text-lg);
    line-height: var(--leading-normal);
    color: var(--text-muted);
  }

  .nowrap {
    white-space: nowrap;
  }

  .cta {
    display: flex;
    gap: var(--space-3);
    justify-content: center;
    flex-wrap: wrap;
    margin-top: var(--space-4);
  }

  .btn {
    display: inline-block;
    padding: var(--space-3) var(--space-6);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--text);
    background: transparent;
    border: 1px solid var(--border-strong);
    border-radius: 999px;
    text-decoration: none;
  }

  .btn:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  .btn.primary {
    background: var(--accent);
    border-color: var(--accent);
    color: #fff;
  }

  .btn.primary:hover {
    background: var(--accent-hover);
    border-color: var(--accent-hover);
    color: #fff;
  }

  .hero :global(.socials) {
    margin-top: var(--space-6);
  }

  .scroll-cue {
    position: absolute;
    bottom: var(--space-8);
    left: 50%;
    transform: translateX(-50%);
    width: 1px;
    height: 40px;
    background: var(--border-strong);
    overflow: hidden;
  }

  .scroll-cue span {
    display: block;
    width: 100%;
    height: 40%;
    background: var(--accent);
    animation: trickle 2.2s var(--ease) infinite;
  }

  @keyframes trickle {
    0% {
      transform: translateY(-100%);
    }
    60%,
    100% {
      transform: translateY(250%);
    }
  }

  /* ---- Blocks ---- */

  .block {
    padding-block: var(--space-16);
  }

  .block-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-4);
    padding-bottom: var(--space-6);
    margin-bottom: var(--space-8);
    border-bottom: 1px solid var(--border);
  }

  .block-head h2 {
    font-size: var(--text-2xl);
  }

  .more {
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    text-decoration: none;
    white-space: nowrap;
  }

  /* ---- Shelf ---- */

  .shelf {
    display: flex;
    align-items: flex-end;
    gap: 5px;
    list-style: none;
    padding: 0;
    margin: 0;
    min-height: 240px;
    overflow-x: auto;
    overflow-y: hidden;
  }

  /* A plain rule, not a plank with a shadow. */
  .plank {
    height: 3px;
    background: var(--border-strong);
  }

  .hint {
    margin-top: var(--space-4);
    font-size: var(--text-sm);
    color: var(--text-faint);
  }

  /* ---- Mosaic ---- */

  .mosaic {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-4);
  }

  .mosaic :global(.cell) {
    min-width: 0;
  }

  .mosaic a {
    position: relative;
    display: block;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    background: var(--bg-subtle);
  }

  .mosaic img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s var(--ease), filter 0.4s var(--ease);
  }

  .mosaic a:hover img {
    transform: scale(1.04);
    filter: brightness(0.7);
  }

  .cap {
    position: absolute;
    left: var(--space-3);
    bottom: var(--space-3);
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    color: #fff;
    opacity: 0;
    transform: translateY(4px);
    transition: opacity 0.3s var(--ease), transform 0.3s var(--ease);
  }

  .mosaic a:hover .cap {
    opacity: 1;
    transform: none;
  }

  .see-more {
    display: block;
    width: fit-content;
    margin: var(--space-8) auto 0;
  }

  @media (max-width: 640px) {
    .hero h1 {
      font-size: var(--text-3xl);
    }
    .mosaic {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-2);
    }
  }
</style>
